OPENAI_API_KEY=

# Optional in dev: if unset, backend/tokens.py generates a random secret
# once at process startup (with a logged warning) and signs tokens with it
# for that process's lifetime only — a restart invalidates every previously
# issued token. Set this to a real secret so issued tokens keep working
# across backend restarts.
STUDENT_TOKEN_SECRET=

# Optional: selects the registry backend behind backend/registry.py.
# "memory" (default) keeps students in an in-memory dict for this process's
# lifetime, rehydrating from CrewAI's own SQLite persistence on a miss.
# "postgres" is not implemented yet (Phase B) and raises NotImplementedError.
REGISTRY_BACKEND=
